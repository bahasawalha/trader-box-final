generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// 👤 Users
// ==========================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String

  role          String   @default("USER")

  name          String?
  avatar        String?
  bio           String?

  referralCode  String   @unique
  referredById  String?
  referredBy    User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("UserReferrals")

  lastWithdrawalAt DateTime?
  lastIp          String?

  subscriptionPrice Decimal @default(29) @db.Decimal(18, 8)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wallet        Wallet?
  subscriptions Subscription[]
  providerSubs  Subscription[] @relation("ProviderSubscriptions")
  deposits      Deposit[]
  withdrawals   Withdrawal[]
  recommendations Recommendation[]
  notifications   Notification[]
  adminMessages   AdminMessage[]
  tickets         Ticket[]
  messages        TicketMessage[]
  auditLogs       AuditLog[]
  analyses        Analysis[]
  roleRequests    RoleRequest[]
  sponsors        Sponsor[]
}


// ==========================
// 🛡️ Role Upgrade Requests
// ==========================

model RoleRequest {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  requestedRole String   // PROVIDER or ANALYST
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason        String?  // Optional justification from user
  adminNote     String?  // Note from admin upon approval/rejection
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


// ==========================
// 💼 Wallet + 🧾 Ledger
// ==========================

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   LedgerEntry[]
}

model LedgerEntry {
  id            String      @id @default(uuid())
  walletId      String
  wallet        Wallet      @relation(fields: [walletId], references: [id])
  type          String
  amount        Decimal @db.Decimal(18, 8)
  balanceAfter  Decimal @db.Decimal(18, 8)
  referenceId   String?     // UUID of the source transaction (Deposit/Withdrawal/Sub)
  createdAt     DateTime    @default(now())
}


// ==========================
// 💰 Financial Operations
// ==========================

model Deposit {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Decimal @db.Decimal(18, 8)
  status      String @default("PENDING")
  method      String
  reference   String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model Withdrawal {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Decimal @db.Decimal(18, 8)
  status      String @default("PENDING")
  method      String
  address     String
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
}


// ==========================
// 🛡️ Audit Trail
// ==========================

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])
  action      String   // e.g., "APPROVE_DEPOSIT", "CHANGE_USER_ROLE"
  targetId    String?  // ID of the target object
  details     String?  // Contextual data
  ip          String?
  createdAt   DateTime @default(now())
}

// ==========================
// 📈 Trading & Subscriptions
// ==========================

model Pair {
  id        String   @id @default(uuid())
  symbol    String   @unique
  name      String
  recs      Recommendation[]
}

model Recommendation {
  id          String   @id @default(uuid())
  pairId      String
  pair        Pair     @relation(fields: [pairId], references: [id])
  providerId  String
  provider    User     @relation(fields: [providerId], references: [id])
  type        String
  entryPrice  Decimal @db.Decimal(18, 8)
  takeProfit  Decimal @db.Decimal(18, 8)
  stopLoss    Decimal @db.Decimal(18, 8)
  status      String      @default("PENDING")
  result      String?
  activatedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
}


model Subscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  providerId  String
  provider    User     @relation("ProviderSubscriptions", fields: [providerId], references: [id])
  price       Decimal @db.Decimal(18, 8)
  startDate   DateTime @default(now())
  endDate     DateTime
  isActive    Boolean  @default(true)
}

// ==========================
// 📊 Content & Support
// ==========================

model Analysis {
  id          String   @id @default(uuid())
  analystId   String
  analyst     User     @relation(fields: [analystId], references: [id])
  title       String
  content     String
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Sponsor {
  id         String   @id @default(uuid())
  name       String
  logo       String
  url        String
  isActive   Boolean  @default(true)
  providerId String?
  provider   User?    @relation(fields: [providerId], references: [id])
  createdAt  DateTime @default(now())
}

model SponsorshipRequest {
  id          String   @id @default(uuid())
  companyName String
  email       String
  website     String?
  license     String?
  type        String   @default("OTHER")
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
}

model Ticket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  status    String   @default("OPEN")
  messages  TicketMessage[]
  createdAt DateTime @default(now())
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model AdminMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, SIGNAL, FINANCIAL
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String   // e.g. USDT (TRC20)
  address   String   // Wallet address
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AppSettings {
  id           String @id @default("global")
  platformFee  Decimal @default(30) @db.Decimal(18, 8)
  updatedAt    DateTime @updatedAt
}
